<Window x:Class="SmartPins.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:SmartPins"
        mc:Ignorable="d"
        Title="SmartPins"
        Height="600" Width="440"
        MinHeight="480" MinWidth="380"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="Blue" SecondaryColor="LightBlue" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

                        <FontFamily x:Key="FiraCode">pack://application:,,,/Fonts/#Fira Code</FontFamily>

                        <SolidColorBrush x:Key="TermBg"           Color="#FF0D0D0D"/>
            <SolidColorBrush x:Key="TermSurface"      Color="#FF141414"/>
            <SolidColorBrush x:Key="TermBorder"       Color="#FF2A2A2A"/>
            <SolidColorBrush x:Key="TermBorderBright" Color="#FF3A3A3A"/>
            <SolidColorBrush x:Key="TermGreen"        Color="#FF39FF14"/>
            <SolidColorBrush x:Key="TermGreenDim"     Color="#FF1A7A09"/>
            <SolidColorBrush x:Key="TermCyan"         Color="#FF00FFFF"/>
            <SolidColorBrush x:Key="TermCyanDim"      Color="#FF006666"/>
            <SolidColorBrush x:Key="TermYellow"       Color="#FFFFD700"/>
            <SolidColorBrush x:Key="TermRed"          Color="#FFFF3B3B"/>
            <SolidColorBrush x:Key="TermText"         Color="#FFCCCCCC"/>
            <SolidColorBrush x:Key="TermTextDim"      Color="#FF666666"/>
            <SolidColorBrush x:Key="TermHover"        Color="#FF1F1F1F"/>

                        <Style x:Key="SepStyle" TargetType="Separator">
                <Setter Property="Background" Value="{StaticResource TermBorder}"/>
                <Setter Property="Margin" Value="0,4"/>
                <Setter Property="Height" Value="1"/>
            </Style>

                        <Style x:Key="BtnPrimary" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TermGreen}"/>
                <Setter Property="BorderBrush" Value="{StaticResource TermGreen}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF234D15"/>
                                    <Setter Property="Foreground" Value="#FFAAFFAA"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#FF0A3006"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

                        <Style x:Key="BtnGhost" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TermText}"/>
                <Setter Property="BorderBrush" Value="{StaticResource TermBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource TermHover}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource TermGreen}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TermGreen}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

                        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                <Setter Property="Foreground" Value="#FFFF3B3B"/>
                <Setter Property="BorderBrush" Value="#FF5A1414"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF300A0A"/>
                                    <Setter Property="BorderBrush" Value="#FFFF3B3B"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

                        <Style x:Key="BtnIcon" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TermTextDim}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource TermHover}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TermText}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

                        <Style x:Key="WinRowStyle" TargetType="ListBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource TermBorder}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,0,0,0">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource TermHover}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

                        <Style x:Key="SlimScroll" TargetType="ScrollBar">
                <Setter Property="Width" Value="5"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid>
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="#FF2A2A2A" CornerRadius="3"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

        <Border CornerRadius="8"
            Background="{StaticResource TermBg}"
            BorderBrush="{StaticResource TermBorder}"
            BorderThickness="1"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>                   <RowDefinition Height="Auto"/>                 <RowDefinition Height="Auto"/>                 <RowDefinition Height="*"/>                    <RowDefinition Height="Auto"/>             </Grid.RowDefinitions>

                        <Border x:Name="TitleBar"
                    Grid.Row="0"
                    Background="{StaticResource TermSurface}"
                    CornerRadius="8,8,0,0"
                    BorderBrush="{StaticResource TermBorder}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="14,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image x:Name="AppIcon" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="SmartPins" FontFamily="{StaticResource FiraCode}" FontSize="14"
                                   FontWeight="Bold" Foreground="{StaticResource TermGreen}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Button Style="{StaticResource BtnIcon}" Click="MinimizeButton_Click">
                            <materialDesign:PackIcon Kind="Minus" Width="14" Height="14"/>
                        </Button>
                        <Button Style="{StaticResource BtnIcon}" Click="CloseButton_Click">
                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

                        <Border Grid.Row="1"
                    Background="{StaticResource TermSurface}"
                    BorderBrush="{StaticResource TermBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="[PIN] " FontFamily="{StaticResource FiraCode}" FontSize="10"
                                   Foreground="{StaticResource TermGreen}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PinnedWindowsCount" Text="0"
                                   FontFamily="{StaticResource FiraCode}" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource TermGreen}" VerticalAlignment="Center"/>
                        <TextBlock Text=" affixed" FontFamily="{StaticResource FiraCode}" FontSize="11"
                                   Foreground="{StaticResource TermTextDim}" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="[WIN] " FontFamily="{StaticResource FiraCode}" FontSize="10"
                                   Foreground="{StaticResource TermCyan}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="VisibleWindowsCount" Text="0"
                                   FontFamily="{StaticResource FiraCode}" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource TermCyan}" VerticalAlignment="Center"/>
                        <TextBlock Text=" visible" FontFamily="{StaticResource FiraCode}" FontSize="11"
                                   Foreground="{StaticResource TermTextDim}" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>

                                        <Border Grid.Column="2"
                            Background="{StaticResource TermBg}"
                            BorderBrush="{StaticResource TermBorder}"
                            BorderThickness="1" CornerRadius="3"
                            Padding="8,4">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Keyboard" Width="12" Height="12"
                                                     Foreground="{StaticResource TermTextDim}"
                                                     VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="CurrentHotkeyText"
                                       Text="Ctrl+Alt+P"
                                       FontFamily="{StaticResource FiraCode}" FontSize="10"
                                       Foreground="{StaticResource TermYellow}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

                        <Border Grid.Row="2"
                    Background="{StaticResource TermBg}"
                    Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <Button Grid.Column="0" Style="{StaticResource BtnGhost}"
                            Padding="0,8" Click="PinWithCursor_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CursorPointer" Width="13" Height="13" Margin="0,0,5,0"/>
                            <TextBlock Text="Курсором"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Style="{StaticResource BtnDanger}"
                            Padding="0,8" Click="UnpinAll_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PinOff" Width="13" Height="13" Margin="0,0,5,0"/>
                            <TextBlock Text="Снять все"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4" Style="{StaticResource BtnIcon}"
                            Click="SettingsButton_Click"
                            Padding="10,8">
                        <materialDesign:PackIcon Kind="Cog" Width="16" Height="16"/>
                    </Button>
                </Grid>
            </Border>

                        <Border Grid.Row="3"
                    Background="{StaticResource TermBg}"
                    BorderBrush="{StaticResource TermBorder}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Background="{StaticResource TermSurface}"
                            Padding="14,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="#" FontFamily="{StaticResource FiraCode}" FontSize="10"
                                       Foreground="{StaticResource TermTextDim}"/>
                            <TextBlock Grid.Column="1" Text="PROCESS // WINDOW TITLE"
                                       FontFamily="{StaticResource FiraCode}" FontSize="10"
                                       Foreground="{StaticResource TermTextDim}"/>
                            <TextBlock Grid.Column="2" Text="ACTION"
                                       FontFamily="{StaticResource FiraCode}" FontSize="10"
                                       Foreground="{StaticResource TermTextDim}" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ListBox x:Name="WindowListBox"
                             Grid.Row="1"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding Windows}"
                             ItemContainerStyle="{StaticResource WinRowStyle}"
                             VirtualizingStackPanel.IsVirtualizing="True">
                        <ListBox.ContextMenu>
                            <ContextMenu Background="{StaticResource TermBg}"
                                         BorderBrush="{StaticResource TermBorder}"
                                         BorderThickness="1"
                                         Padding="0"
                                         HasDropShadow="True">
                                <ContextMenu.Effect>
                                    <DropShadowEffect Color="#FF39FF14" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                                </ContextMenu.Effect>
                                <ContextMenu.Template>
                                    <ControlTemplate TargetType="ContextMenu">
                                        <Border Background="{StaticResource TermBg}"
                                                BorderBrush="{StaticResource TermBorder}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                MinWidth="200">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#FF39FF14" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                                            </Border.Effect>
                                            <StackPanel IsItemsHost="True" Margin="0,4,0,4"/>
                                        </Border>
                                    </ControlTemplate>
                                </ContextMenu.Template>
                                <MenuItem Click="AddToBlacklist_Click"
                                          Background="Transparent"
                                          Foreground="{StaticResource TermText}"
                                          FontFamily="{StaticResource FiraCode}"
                                          FontSize="12">
                                    <MenuItem.Style>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="MenuItem">
                                                        <Border x:Name="Bd" Background="Transparent"
                                                                Padding="12,7" Margin="4,1" CornerRadius="4">
                                                            <StackPanel Orientation="Horizontal">
                                                                <materialDesign:PackIcon Kind="Cancel"
                                                                    Width="14" Height="14"
                                                                    Foreground="#FFFF3B3B"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,8,0"/>
                                                                <TextBlock Text="Добавить в блэклист"
                                                                           FontFamily="{StaticResource FiraCode}"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource TermText}"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsHighlighted" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource TermHover}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource TermGreen}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.Template>
                            <ControlTemplate TargetType="ListBox">
                                <ScrollViewer Focusable="False" HorizontalScrollBarVisibility="Disabled">
                                    <ScrollViewer.Resources>
                                        <Style TargetType="ScrollBar">
                                            <Setter Property="MinWidth" Value="5"/>
                                            <Setter Property="Width" Value="5"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ScrollBar">
                                                        <Grid Background="Transparent">
                                                            <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="1">
                                                                <Track.Thumb>
                                                                    <Thumb>
                                                                        <Thumb.Template>
                                                                            <ControlTemplate TargetType="Thumb">
                                                                                <Border Background="#FF3A3A3A" CornerRadius="3"/>
                                                                            </ControlTemplate>
                                                                        </Thumb.Template>
                                                                    </Thumb>
                                                                </Track.Thumb>
                                                            </Track>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ScrollViewer.Resources>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ListBox.Template>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:WindowInfo}">
                                <Grid Margin="14,6,18,6" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                                                        <materialDesign:PackIcon Grid.Column="0"
                                               Kind="{Binding PinIndicatorIcon}"
                                               Width="12" Height="12"
                                               Foreground="{Binding PinColor}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0"/>

                                                                        <Image Grid.Column="1"
                                           Source="{Binding Icon}"
                                           Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0"
                                           ClipToBounds="True"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>

                                                                        <TextBlock Grid.Column="2"
                                               Text="{Binding Title}"
                                               FontFamily="{StaticResource FiraCode}"
                                               FontSize="12"
                                               Foreground="{Binding TitleColor}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                                                        <Button Grid.Column="3"
                                            Command="{Binding PinCommand}"
                                            FontFamily="{StaticResource FiraCode}"
                                            FontSize="10"
                                            Height="24"
                                            Foreground="{Binding PinColor}"
                                            Background="Transparent"
                                            BorderBrush="{Binding PinColor}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="3">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="{Binding PinButtonIcon}" Width="11" Height="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding PinButtonText}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

                        <Border Grid.Row="4"
                    Background="{StaticResource TermSurface}"
                    BorderBrush="{StaticResource TermBorder}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8"
                    Padding="14,7">
                <Grid>
                    <TextBlock Text="$ smartpins --running" FontFamily="{StaticResource FiraCode}" FontSize="10"
                               Foreground="{StaticResource TermTextDim}"/>
                    <TextBlock x:Name="StatusText" Text=""
                               FontFamily="{StaticResource FiraCode}" FontSize="10"
                               Foreground="{StaticResource TermGreen}"
                               HorizontalAlignment="Right"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
