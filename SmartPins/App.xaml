<Application x:Class="SmartPins.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Fira Code embedded -->
            <FontFamily x:Key="FiraCode">pack://application:,,,/Fonts/#Fira Code</FontFamily>

            <!-- Terminal palette -->
            <SolidColorBrush x:Key="TermBg"           Color="#FF0D0D0D"/>
            <SolidColorBrush x:Key="TermSurface"      Color="#FF141414"/>
            <SolidColorBrush x:Key="TermBorder"       Color="#FF2A2A2A"/>
            <SolidColorBrush x:Key="TermBorderBright" Color="#FF3A3A3A"/>
            <SolidColorBrush x:Key="TermGreen"        Color="#FF39FF14"/>
            <SolidColorBrush x:Key="TermGreenDim"     Color="#FF1A7A09"/>
            <SolidColorBrush x:Key="TermCyan"         Color="#FF00FFFF"/>
            <SolidColorBrush x:Key="TermCyanDim"      Color="#FF006666"/>
            <SolidColorBrush x:Key="TermYellow"       Color="#FFFFD700"/>
            <SolidColorBrush x:Key="TermRed"          Color="#FFFF3B3B"/>
            <SolidColorBrush x:Key="TermText"         Color="#FFCCCCCC"/>
            <SolidColorBrush x:Key="TermTextDim"      Color="#FF666666"/>
            <SolidColorBrush x:Key="TermHover"        Color="#FF1F1F1F"/>

            <!-- Tray context menu -->
            <Style x:Key="TrayMenuStyle" TargetType="ContextMenu">
                <Setter Property="Background" Value="#FF0D0D0D"/>
                <Setter Property="BorderBrush" Value="#FF2A2A2A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="HasDropShadow" Value="True"/>
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    MinWidth="210">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF39FF14" BlurRadius="16" ShadowDepth="0" Opacity="0.10"/>
                                </Border.Effect>
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"
                                            Margin="0,4,0,4"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TrayItemStyle" TargetType="MenuItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#FFAAAAAA"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="Padding" Value="14,7"/>
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="Bd" Background="Transparent"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="4,1,4,1"
                                    CornerRadius="4">
                                <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FF1A1A1A"/>
                                    <Setter Property="Foreground" Value="#FF39FF14"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#FF444444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="MenuItem" BasedOn="{StaticResource TrayItemStyle}"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
