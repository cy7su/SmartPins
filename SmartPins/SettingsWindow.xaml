<Window x:Class="SmartPins.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Settings" Height="480" Width="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="Blue" SecondaryColor="LightBlue" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="FiraCode">pack://application:,,,/Fonts/#Fira Code</FontFamily>
            <SolidColorBrush x:Key="TermBg"      Color="#FF0D0D0D"/>
            <SolidColorBrush x:Key="TermSurface" Color="#FF141414"/>
            <SolidColorBrush x:Key="TermBorder"  Color="#FF2A2A2A"/>
            <SolidColorBrush x:Key="TermGreen"   Color="#FF39FF14"/>
            <SolidColorBrush x:Key="TermGreenDim" Color="#FF1A7A09"/>
            <SolidColorBrush x:Key="TermCyan"    Color="#FF00FFFF"/>
            <SolidColorBrush x:Key="TermYellow"  Color="#FFFFD700"/>
            <SolidColorBrush x:Key="TermText"    Color="#FFCCCCCC"/>
            <SolidColorBrush x:Key="TermTextDim" Color="#FF666666"/>
            <SolidColorBrush x:Key="TermHover"   Color="#FF1F1F1F"/>
            <SolidColorBrush x:Key="TermRed"     Color="#FFFF3B3B"/>

            <Style x:Key="BtnPrimary" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource TermGreenDim}"/>
                <Setter Property="Foreground" Value="{StaticResource TermGreen}"/>
                <Setter Property="BorderBrush" Value="{StaticResource TermGreen}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily" Value="{StaticResource FiraCode}"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF234D15"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="BtnGhost" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TermText}"/>
                <Setter Property="BorderBrush" Value="{StaticResource TermBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily" Value="{StaticResource FiraCode}"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource TermHover}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource TermGreen}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TermGreen}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="BtnIcon" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TermTextDim}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource TermHover}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TermText}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="TermToggle" TargetType="ToggleButton">
                <Setter Property="Width" Value="44"/>
                <Setter Property="Height" Value="22"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid>
                                <Border x:Name="Track" CornerRadius="11"
                                        Background="{StaticResource TermBorder}"
                                        Height="22" Width="44"/>
                                <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White"
                                         HorizontalAlignment="Left" Margin="2,0,0,0"
                                         VerticalAlignment="Center"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Track" Property="Background" Value="{StaticResource TermGreenDim}"/>
                                    <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                                    <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource TermGreen}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="8" Background="{StaticResource TermBg}"
            BorderBrush="{StaticResource TermBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <Border x:Name="TitleBar" Grid.Row="0"
                    Background="{StaticResource TermSurface}"
                    CornerRadius="8,8,0,0"
                    BorderBrush="{StaticResource TermBorder}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="14,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image x:Name="AppIcon" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="settings" FontFamily="{StaticResource FiraCode}" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource TermGreen}"/>
                    </StackPanel>
                    <Button Style="{StaticResource BtnIcon}" Click="CloseButton_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                    </Button>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="20,16,20,0" VerticalAlignment="Top">

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="highlight pinned windows"
                                   FontFamily="{StaticResource FiraCode}" FontSize="12"
                                   Foreground="{StaticResource TermText}"/>
                        <TextBlock Text="// show glowing border around pinned windows"
                                   FontFamily="{StaticResource FiraCode}" FontSize="10"
                                   Foreground="{StaticResource TermTextDim}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ToggleButton x:Name="HighlightToggle"
                                  Grid.Column="1"
                                  Style="{StaticResource TermToggle}"
                                  VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="show pin icon on window"
                                   FontFamily="{StaticResource FiraCode}" FontSize="12"
                                   Foreground="{StaticResource TermText}"/>
                        <TextBlock Text="// show pin.ico overlay on pinned windows"
                                   FontFamily="{StaticResource FiraCode}" FontSize="10"
                                   Foreground="{StaticResource TermTextDim}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ToggleButton x:Name="PinIconToggle"
                                  Grid.Column="1"
                                  Style="{StaticResource TermToggle}"
                                  VerticalAlignment="Center"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="hotkey" FontFamily="{StaticResource FiraCode}" FontSize="12"
                                   Foreground="{StaticResource TermText}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="// current: " FontFamily="{StaticResource FiraCode}" FontSize="10"
                                       Foreground="{StaticResource TermTextDim}"/>
                            <TextBlock x:Name="HotkeyLabel" Text="Ctrl+Alt+P"
                                       FontFamily="{StaticResource FiraCode}" FontSize="10"
                                       Foreground="{StaticResource TermYellow}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="[ change ]"
                            Style="{StaticResource BtnGhost}"
                            Height="30" Click="HotkeyButton_Click"/>
                </Grid>

                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="100"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="blacklist"
                               FontFamily="{StaticResource FiraCode}" FontSize="12"
                               Foreground="{StaticResource TermText}"/>
                    <TextBlock Grid.Row="1" Text="// matches if process name contains the string (case-insensitive)"
                               FontFamily="{StaticResource FiraCode}" FontSize="10"
                               Foreground="{StaticResource TermTextDim}" Margin="0,2,0,6"/>
                    <Grid Grid.Row="2" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="BlacklistInput"
                                 FontFamily="{StaticResource FiraCode}" FontSize="11"
                                 Background="#FF141414" Foreground="{StaticResource TermText}"
                                 BorderBrush="{StaticResource TermBorder}" BorderThickness="1"
                                 CaretBrush="{StaticResource TermGreen}"
                                 Height="26" Padding="4,3">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <Button Grid.Column="2" Content="[ add ]"
                                Style="{StaticResource BtnGhost}"
                                Height="26" Click="AddBlacklist_Click"/>
                        <Button Grid.Column="4" Content="[ del ]"
                                Style="{StaticResource BtnGhost}"
                                Height="26" Click="RemoveBlacklist_Click"
                                Foreground="{StaticResource TermRed}"
                                BorderBrush="#FF5A1414"/>
                    </Grid>
                    <ListBox x:Name="BlacklistBox" Grid.Row="3"
                             Background="#FF0D0D0D"
                             BorderBrush="{StaticResource TermBorder}"
                             BorderThickness="1"
                             FontFamily="{StaticResource FiraCode}" FontSize="11"
                             Foreground="{StaticResource TermText}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             KeyDown="BlacklistBox_KeyDown">
                        <ListBox.Template>
                            <ControlTemplate TargetType="ListBox">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4">
                                    <ScrollViewer Focusable="False" HorizontalScrollBarVisibility="Disabled">
                                        <ScrollViewer.Resources>
                                            <Style TargetType="ScrollBar">
                                                <Setter Property="MinWidth" Value="5"/>
                                                <Setter Property="Width" Value="5"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ScrollBar">
                                                            <Grid Background="Transparent">
                                                                <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="1">
                                                                    <Track.Thumb>
                                                                        <Thumb>
                                                                            <Thumb.Template>
                                                                                <ControlTemplate TargetType="Thumb">
                                                                                    <Border Background="{StaticResource TermBorderBright}" CornerRadius="3"/>
                                                                                </ControlTemplate>
                                                                            </Thumb.Template>
                                                                        </Thumb>
                                                                    </Track.Thumb>
                                                                </Track>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ScrollViewer.Resources>
                                        <ItemsPresenter Margin="2"/>
                                    </ScrollViewer>
                                </Border>
                            </ControlTemplate>
                        </ListBox.Template>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="6,3"/>
                                <Setter Property="Foreground" Value="{StaticResource TermText}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}" CornerRadius="3">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource TermHover}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FF1A3A0A"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TermGreen}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </StackPanel>

            <Border Grid.Row="2"
                    Background="{StaticResource TermSurface}"
                    BorderBrush="{StaticResource TermBorder}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="[ cancel ]" Style="{StaticResource BtnGhost}"
                            Height="30" Width="90" Margin="0,0,10,0"
                            Click="CancelButton_Click"/>
                    <Button Content="[ save ]" Style="{StaticResource BtnPrimary}"
                            Height="30" Width="90" Click="SaveButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
