<Window x:Class="SmartPins.HotkeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Hotkey" Height="400" Width="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="Blue" SecondaryColor="LightBlue" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="FiraCode">pack://application:,,,/Fonts/#Fira Code</FontFamily>
            <SolidColorBrush x:Key="TermBg"       Color="#FF0D0D0D"/>
            <SolidColorBrush x:Key="TermSurface"  Color="#FF141414"/>
            <SolidColorBrush x:Key="TermBorder"   Color="#FF2A2A2A"/>
            <SolidColorBrush x:Key="TermGreen"    Color="#FF39FF14"/>
            <SolidColorBrush x:Key="TermGreenDim" Color="#FF1A7A09"/>
            <SolidColorBrush x:Key="TermText"     Color="#FFCCCCCC"/>
            <SolidColorBrush x:Key="TermTextDim"  Color="#FF666666"/>
            <SolidColorBrush x:Key="TermHover"    Color="#FF1F1F1F"/>
            <SolidColorBrush x:Key="TermYellow"   Color="#FFFFD700"/>

            <Style x:Key="BtnPrimary" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TermGreen}"/>
                <Setter Property="BorderBrush" Value="{StaticResource TermGreen}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily" Value="{StaticResource FiraCode}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF234D15"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="BtnGhost" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TermText}"/>
                <Setter Property="BorderBrush" Value="{StaticResource TermBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily" Value="{StaticResource FiraCode}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource TermHover}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource TermGreen}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TermGreen}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="BtnIcon" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TermTextDim}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource TermHover}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TermText}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="8" Background="{StaticResource TermBg}"
            BorderBrush="{StaticResource TermBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

                        <Border x:Name="TitleBar" Grid.Row="0"
                    Background="{StaticResource TermSurface}"
                    CornerRadius="8,8,0,0"
                    BorderBrush="{StaticResource TermBorder}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="14,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image x:Name="AppIcon" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="hotkey" FontFamily="{StaticResource FiraCode}" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource TermGreen}"/>
                        <TextBlock Text=" --set" FontFamily="{StaticResource FiraCode}" FontSize="10"
                                   Foreground="{StaticResource TermTextDim}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    <Button Style="{StaticResource BtnIcon}" Click="CloseButton_Click"
                            HorizontalAlignment="Left" ToolTip="Закрыть" Margin="390,11,0,11" Width="20">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" RenderTransformOrigin="0.161,0.25" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

                        <StackPanel Grid.Row="1" Margin="20,16,20,0">
                                <TextBlock Text="// press a key combination below"
                           FontFamily="{StaticResource FiraCode}" FontSize="10"
                           Foreground="{StaticResource TermTextDim}"
                           Margin="0,0,0,16"/>

                                <Border Background="{StaticResource TermSurface}"
                        BorderBrush="{StaticResource TermBorder}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="16,12" Margin="0,0,0,16"
                        Height="52">
                    <TextBlock x:Name="HotkeyDisplay"
                               Text="press keys..."
                               FontFamily="{StaticResource FiraCode}" FontSize="18"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TermTextDim}"/>
                </Border>

                                <Button Content="[ clear ]" Style="{StaticResource BtnGhost}"
                        Height="30" Width="100" HorizontalAlignment="Left"
                        Click="ClearButton_Click" Margin="0,0,0,20"/>

                                <TextBlock Text="// presets:" FontFamily="{StaticResource FiraCode}" FontSize="10"
                           Foreground="{StaticResource TermTextDim}" Margin="0,0,0,10"/>
                <UniformGrid Columns="3" Rows="2">
                    <Button Style="{StaticResource BtnGhost}" Tag="Ctrl+Alt+P"  Click="PresetHotkey_Click" Margin="0,0,6,6" Height="30">
                        <TextBlock Text="Ctrl+Alt+P" FontFamily="{StaticResource FiraCode}" FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource BtnGhost}" Tag="Ctrl+Shift+P" Click="PresetHotkey_Click" Margin="0,0,6,6" Height="30">
                        <TextBlock Text="Ctrl+Shift+P" FontFamily="{StaticResource FiraCode}" FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource BtnGhost}" Tag="Win+P"       Click="PresetHotkey_Click" Margin="0,0,0,6" Height="30">
                        <TextBlock Text="Win+P" FontFamily="{StaticResource FiraCode}" FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource BtnGhost}" Tag="F12"         Click="PresetHotkey_Click" Margin="0,0,6,0" Height="30">
                        <TextBlock Text="F12" FontFamily="{StaticResource FiraCode}" FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource BtnGhost}" Tag="Ctrl+F12"    Click="PresetHotkey_Click" Margin="0,0,6,0" Height="30">
                        <TextBlock Text="Ctrl+F12" FontFamily="{StaticResource FiraCode}" FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource BtnGhost}" Tag="Alt+F12"     Click="PresetHotkey_Click" Margin="0" Height="30">
                        <TextBlock Text="Alt+F12" FontFamily="{StaticResource FiraCode}" FontSize="10"/>
                    </Button>
                </UniformGrid>
            </StackPanel>

                        <Border Grid.Row="2"
                    Background="{StaticResource TermSurface}"
                    BorderBrush="{StaticResource TermBorder}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="[ cancel ]" Style="{StaticResource BtnGhost}"
                            Height="30" Width="90" Margin="0,0,10,0" Click="CancelButton_Click"/>
                    <Button Content="[ apply ]"  Style="{StaticResource BtnPrimary}"
                            Height="30" Width="90" Click="SaveButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
